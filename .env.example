# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DB=jobradar
PG_USER=admin
PG_PASSWORD=secret
DATABASE_URL=postgresql://admin:secret@localhost:5432/jobradar

# Hive
HIVE_HOST=localhost
HIVE_PORT=10000

# France Travail API
# Register on https://francetravail.io/data/api
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# API security
SECRET_KEY=change-me-32-chars-minimum
