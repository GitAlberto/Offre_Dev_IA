# PostgreSQL
PG_HOST=localhost
PG_PORT=5433
PG_DB=jobradar
PG_USER=admin
PG_PASSWORD=secret
DATABASE_URL=postgresql://admin:secret@localhost:5433/jobradar

# Hive
HIVE_HOST=localhost
HIVE_PORT=10010
HIVE_DATABASE=default
HIVE_AUTH=NOSASL
HIVE_BEELINE_CONTAINER=jobradar-hive
HUE_PORT=8888

# France Travail API
# S'inscrire sur https://francetravail.io/data/api
# Exemple de scope pour l'API des offres d'emploi : api_offresdemploiv2 o2dsoffre
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
FRANCE_TRAVAIL_SCOPE=
# Strategie de collecte : `legacy`, `focused`, `broad`, `max_volume`
FRANCE_TRAVAIL_QUERY_MODE=broad
# Taille d'une page par requete. L'API limite actuellement chaque page a 150 lignes.
FRANCE_TRAVAIL_MAX_RESULTS=150
# Nombre de pages a lire par groupe de mots-cles. Utiliser 0 pour "toutes les pages disponibles".
FRANCE_TRAVAIL_MAX_PAGES=20
FRANCE_TRAVAIL_TIMEOUT_SECONDS=30

# Adzuna
# Creer un compte developpeur sur https://developer.adzuna.com/
# puis renseigner `app_id` et `app_key`.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=fr
ADZUNA_QUERY_MODE=focused
ADZUNA_RESULTS_PER_PAGE=50
ADZUNA_MAX_PAGES=3
ADZUNA_TIMEOUT_SECONDS=60
# `true` pour ne garder que les annonces avec salaire structure.
ADZUNA_REQUIRE_SALARY=true
# `true` pour exclure les salaires marques comme predits par Adzuna.
ADZUNA_EXCLUDE_PREDICTED_SALARY=false

# Welcome to the Jungle
# Strategie de requetes : `legacy`, `focused`, `broad`, `max_volume`
WTTJ_QUERY_MODE=focused
# Nombre de pages WTTJ a parcourir par requete metier.
WTTJ_MAX_PAGES=10
# Timeout maximum par page chargee avec Selenium.
WTTJ_TIMEOUT_SECONDS=30
# Timeout court de preverification HTTP avant de lancer Selenium sur une requete.
WTTJ_PREFLIGHT_TIMEOUT_SECONDS=10
# Optionnel : chemin explicite vers le binaire Chrome si Selenium ne le detecte pas seul.
WTTJ_CHROME_BINARY=

# BPCE
# Optionnel : si vide, le collecteur cherchera d'abord
# `data/source_csv/bpce.csv` puis le CSV BPCE le plus recent du dossier.
BPCE_CSV_PATH=

# Region Ile-de-France
# Optionnel : si vide, le collecteur cherchera d'abord
# `data/source_csv/region_ile_de_france.csv` puis le CSV IDF le plus recent du dossier.
REGION_ILE_DE_FRANCE_CSV_PATH=

# Securite API
SECRET_KEY=change-me-32-chars-minimum
